{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "//": "Enforced guardrails for --dangerously-skip-permissions. Rules evaluate deny -> ask -> allow; first match wins. deny and ask rules apply EVEN in bypassPermissions mode; allow rules do not. Keep deny rules in this committed file (not settings.local.json) so they cannot be overridden. Bash() globs: the space before * is a word boundary, e.g. Bash(rm -rf *) matches 'rm -rf x' but not 'rm-rfx'. Argument-shape blocks (pipe-to-shell, .env reads) are handled by the hook, not these globs, because arg-constraining globs are unreliable.",

  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*.local)",
      "Read(./.env.development)",
      "Read(./.env.production)",
      "Read(./.env.staging)",
      "Read(./.env.test)",
      "Read(./**/.env)",
      "Read(./**/.env.local)",
      "Read(./secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.netrc)",
      "Read(~/.config/gh/hosts.yml)",

      "Edit(./.env)",
      "Edit(./.env.local)",
      "Edit(./.env.*.local)",
      "Edit(./.env.development)",
      "Edit(./.env.production)",
      "Edit(./.env.staging)",
      "Edit(./.env.test)",
      "Edit(./**/.env)",
      "Edit(./**/.env.local)",
      "Edit(./secrets/**)",
      "Edit(./.git/**)",
      "Edit(./.github/workflows/**)",
      "Edit(./.claude/settings.json)",
      "Edit(./.mcp.json)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.profile)",
      "Edit(~/.npmrc)",
      "Edit(~/.config/hypr/**)",
      "Write(/etc/**)",
      "Write(/usr/**)",

      "Bash(sudo *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(npm publish*)",
      "Bash(pnpm publish*)",
      "Bash(yarn publish*)",
      "Bash(supabase db reset*)",
      "Bash(pacman *)",
      "Bash(yay *)"
    ],

    "ask": [
      "Bash(git push *)",
      "Bash(gh pr merge *)",
      "Bash(vercel *)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/yolo-guard.sh"
          }
        ]
      }
    ]
  }
}
